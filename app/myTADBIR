<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>myTADBIR - Perancangan Harta Islam</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Babel -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <!-- Import Map -->
    <script type="importmap">
      {
        "imports": {
          "react": "https://esm.sh/react@18.2.0",
          "react-dom/client": "https://esm.sh/react-dom@18.2.0/client",
          "lucide-react": "https://esm.sh/lucide-react@0.292.0"
        }
      }
    </script>

    <style>
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .animate-fadeIn { animation: fadeIn 0.5s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="bg-slate-50">
    
    <div id="root"></div>

    <script type="text/babel" data-type="module">
        import React, { useState, useMemo } from 'react';
        import { createRoot } from 'react-dom/client';
        import { 
          Landmark, ShieldCheck, HeartHandshake, BookOpen, 
          TrendingUp, Calculator, PieChart, Wallet, User, 
          AlertTriangle, Heart, Lightbulb, Clock, FileText, ArrowRight, Printer, MessageCircle
        } from 'lucide-react';

        // --- Komponen Bantuan (UI) ---
        const Card = ({ children, className = '' }) => (
          <div className={`bg-white rounded-xl shadow-sm border border-slate-200 p-6 ${className}`}>
            {children}
          </div>
        );

        const Input = ({ label, value, onChange, type = 'number', prefix = '', suffix = '', min = 0, max }) => (
          <div className="flex flex-col mb-4">
            <label className="text-sm font-semibold text-slate-700 mb-1">{label}</label>
            <div className="relative flex items-center">
              {prefix && <span className="absolute left-3 text-slate-500">{prefix}</span>}
              <input
                type={type}
                value={value}
                onChange={onChange}
                min={min}
                max={max}
                className={`w-full border border-slate-300 rounded-lg py-2 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all ${prefix ? 'pl-9' : 'pl-3'} ${suffix ? 'pr-8' : 'pr-3'}`}
              />
              {suffix && <span className="absolute right-3 text-slate-500">{suffix}</span>}
            </div>
          </div>
        );

        const SectionHeader = ({ title, icon: Icon, description }) => (
          <div className="mb-6 border-b border-emerald-100 pb-4">
            <div className="flex items-center gap-3">
              <div className="p-2 bg-emerald-100 text-emerald-700 rounded-lg">
                <Icon size={24} />
              </div>
              <div>
                <h2 className="text-xl font-bold text-slate-800">{title}</h2>
                <p className="text-sm text-slate-500">{description}</p>
              </div>
            </div>
          </div>
        );

        // --- Komponen Utama ---
        function App() {
          const [activeTab, setActiveTab] = useState(1);
          const [showReport, setShowReport] = useState(false);

          // === STATE PENGURUSAN DATA ===
          const [userGender, setUserGender] = useState('lelaki');
          const [age, setAge] = useState(30);
          const [annualIncome, setAnnualIncome] = useState(60000);
          const [currentExpenses, setCurrentExpenses] = useState(3000);
          const [childrenData, setChildrenData] = useState([{ id: 1, age: 1, gender: 'lelaki' }]);
          
          const [asb, setAsb] = useState(10000);
          const [th, setTh] = useState(10000);
          const [unitTrust, setUnitTrust] = useState(5000);
          const [tunai, setTunai] = useState(20000);
          const [kwsp, setKwsp] = useState(80000);
          const [emas, setEmas] = useState(5000);
          
          const [rumahValue, setRumahValue] = useState(350000);
          const [rumahBaki, setRumahBaki] = useState(300000);
          const [rumahTempoh, setRumahTempoh] = useState(25);
          
          const [keretaValue, setKeretaValue] = useState(60000);
          const [keretaBaki, setKeretaBaki] = useState(45000);
          const [keretaTempoh, setKeretaTempoh] = useState(7);
          
          const [personalBaki, setPersonalBaki] = useState(15000);
          const [personalTempoh, setPersonalTempoh] = useState(5);

          const [retireAge, setRetireAge] = useState(60);
          const [lifeExpectancy, setLifeExpectancy] = useState(80);
          const [inflationRate, setInflationRate] = useState(3);
          const [assetReturnRate, setAssetReturnRate] = useState(5);
          const [uniAge, setUniAge] = useState(18);
          const [currentEduCost, setCurrentEduCost] = useState(50000);

          const [funeralCost, setFuneralCost] = useState(2000);
          const [sepencarianPercent, setSepencarianPercent] = useState(50); 
          const [wasiatPercent, setWasiatPercent] = useState(0); 
          const [hasSpouse, setHasSpouse] = useState(true);
          const [parentsAlive, setParentsAlive] = useState(2); 

          const [currentTakaful, setCurrentTakaful] = useState(100000);

          // === PENGIRAAN AUTOMATIK ===
          const numSons = childrenData.filter(c => c.gender === 'lelaki').length;
          const numDaughters = childrenData.filter(c => c.gender === 'perempuan').length;
          const spouseGender = userGender === 'lelaki' ? 'isteri' : 'suami';

          const totalLiquidAssets = asb + th + unitTrust + tunai + kwsp + emas;
          const totalPhysicalAssets = rumahValue + keretaValue;
          const totalDebts = rumahBaki + keretaBaki + personalBaki;
          const currentNetWorth = (totalLiquidAssets + totalPhysicalAssets) - totalDebts;

          const yearsToRetire = Math.max(0, retireAge - age);
          const yearsInRetirement = Math.max(0, lifeExpectancy - retireAge);
          
          const futureMonthlyExpenses = currentExpenses * Math.pow(1 + (inflationRate / 100), yearsToRetire);
          const retirementCorpusNeeded = futureMonthlyExpenses * 12 * yearsInRetirement;
          
          const futureEduCostTotal = childrenData.reduce((total, child) => {
            const yearsToUni = Math.max(0, uniAge - child.age);
            return total + (currentEduCost * Math.pow(1 + (inflationRate / 100), yearsToUni));
          }, 0);

          const futureLiquidAssets = totalLiquidAssets * Math.pow(1 + (assetReturnRate / 100), yearsToRetire);
          
          const unjuranRumahBaki = yearsToRetire >= rumahTempoh ? 0 : Math.max(0, rumahBaki - (rumahBaki / rumahTempoh) * yearsToRetire);
          const unjuranKeretaBaki = yearsToRetire >= keretaTempoh ? 0 : Math.max(0, keretaBaki - (keretaBaki / keretaTempoh) * yearsToRetire);
          const unjuranPersonalBaki = yearsToRetire >= personalTempoh ? 0 : Math.max(0, personalBaki - (personalBaki / personalTempoh) * yearsToRetire);
          const unjuranTotalDebts = unjuranRumahBaki + unjuranKeretaBaki + unjuranPersonalBaki;

          const bakiUntukBersara = Math.max(0, futureLiquidAssets - unjuranTotalDebts - futureEduCostTotal);
          const yearlyRetirementExpense = futureMonthlyExpenses * 12;
          const yearsItWillLast = yearlyRetirementExpense > 0 ? (bakiUntukBersara / yearlyRetirementExpense) : 0;
          const exhaustAge = retireAge + yearsItWillLast;

          // --- PENGIRAAN SOLUSI PERSARAAN ---
          const totalFutureNeeds = unjuranTotalDebts + futureEduCostTotal + retirementCorpusNeeded;
          const retirementShortfall = Math.max(0, totalFutureNeeds - futureLiquidAssets);
          // Opsyen A: Extra savings needed monthly (Simplified PMT)
          const extraSavingsNeeded = yearsToRetire > 0 ? (retirementShortfall / (yearsToRetire * 12)) : 0;
          // Opsyen C: Downsize lifestyle
          const sustainableMonthlyExpense = yearsInRetirement > 0 ? (bakiUntukBersara / (yearsInRetirement * 12)) : 0;

          // --- PENGIRAAN FARAID & HARTA ---
          const totalZakatable = asb + th + unitTrust + tunai + emas; 
          const zakatPayable = totalZakatable * 0.025;

          const grossEstate = totalLiquidAssets + totalPhysicalAssets;
          const estateAfterFuneral = grossEstate - funeralCost;
          
          const sepencarianAmount = hasSpouse ? (totalPhysicalAssets * (sepencarianPercent / 100)) : 0;
          
          const estateAfterSepencarian = estateAfterFuneral - sepencarianAmount;
          const estateAfterDebts = estateAfterSepencarian - totalDebts - zakatPayable; 
          const actualNetEstate = Math.max(0, estateAfterDebts);
          
          const wasiatAmount = actualNetEstate * (Math.min(wasiatPercent, 33.33) / 100);
          const faraidPool = actualNetEstate - wasiatAmount;

          const calculateFaraid = () => {
            let distribution = [];
            let pool = faraidPool;
            if (pool <= 0) return [];

            let spouseShare = 0; let motherShare = 0; let fatherShare = 0; let daughtersShare = 0;
            
            if (hasSpouse) {
              if (spouseGender === 'isteri') {
                spouseShare = (numSons > 0 || numDaughters > 0) ? 1/8 : 1/4;
                distribution.push({ name: 'Isteri', amount: pool * spouseShare, percent: spouseShare * 100, isSpouse: true });
              } else {
                spouseShare = (numSons > 0 || numDaughters > 0) ? 1/4 : 1/2;
                distribution.push({ name: 'Suami', amount: pool * spouseShare, percent: spouseShare * 100, isSpouse: true });
              }
            }

            if (parentsAlive > 0) {
              let parentShareCalc = (numSons > 0 || numDaughters > 0) ? 1/6 : 1/3;
              if (parentsAlive === 2 || parentsAlive === 1) {
                  motherShare = parentShareCalc;
                  const parentName = parentsAlive === 1 ? 'Ibu/Bapa' : 'Ibu';
                  distribution.push({ name: parentName, amount: pool * motherShare, percent: motherShare * 100 });
              }
              if (parentsAlive === 2) {
                  fatherShare = (numSons > 0 || numDaughters > 0) ? 1/6 : 0;
                  distribution.push({ name: 'Bapa', amount: pool * fatherShare, percent: fatherShare * 100 });
              }
            }

            if (numSons === 0 && numDaughters > 0) {
              daughtersShare = numDaughters === 1 ? 1/2 : 2/3;
              distribution.push({ name: `Anak Perempuan (${numDaughters} orang)`, amount: pool * daughtersShare, percent: daughtersShare * 100 });
            }

            let allocatedFraction = spouseShare + motherShare + fatherShare + daughtersShare;
            
            if (allocatedFraction > 1) {
              distribution = distribution.map(d => {
                let newFraction = (d.percent / 100) / allocatedFraction;
                return { ...d, amount: pool * newFraction, percent: newFraction * 100 };
              });
              allocatedFraction = 1;
            }

            let remainingFraction = 1 - allocatedFraction;
            let remainingAmount = pool * remainingFraction;

            if (remainingFraction > 0.0001) {
              if (numSons > 0) {
                const totalParts = (numSons * 2) + numDaughters;
                const valuePerPart = remainingAmount / totalParts;
                distribution.push({ name: `Anak Lelaki (${numSons} orang)`, amount: valuePerPart * 2 * numSons, percent: (valuePerPart * 2 * numSons / pool) * 100 });
                if (numDaughters > 0) {
                  distribution.push({ name: `Anak Perempuan (${numDaughters} orang)`, amount: valuePerPart * numDaughters, percent: (valuePerPart * numDaughters / pool) * 100 });
                }
              } else if (parentsAlive === 2) {
                let fatherIndex = distribution.findIndex(d => d.name === 'Bapa');
                if(fatherIndex !== -1) {
                    distribution[fatherIndex].amount += remainingAmount;
                    distribution[fatherIndex].percent += (remainingFraction * 100);
                    distribution[fatherIndex].name = 'Bapa (Fardu + Asabah)';
                } else {
                    distribution.push({ name: 'Bapa (Asabah)', amount: remainingAmount, percent: remainingFraction * 100 });
                }
              } else {
                distribution.push({ name: 'Baitulmal / Waris Lain (Adik Beradik)', amount: remainingAmount, percent: remainingFraction * 100 });
              }
            }

            return distribution;
          };

          const faraidDistribution = calculateFaraid();

          const spouseFaraidObj = faraidDistribution.find(d => d.isSpouse);
          const spouseFaraidAmount = spouseFaraidObj ? spouseFaraidObj.amount : 0;
          
          const totalSpouseSurvivalFund = sepencarianAmount + spouseFaraidAmount + currentTakaful;
          const familySurvivalNeeds = currentExpenses * 12 * 10;
          const incomeProtectionGap = Math.max(0, familySurvivalNeeds - totalSpouseSurvivalFund);

          const tabs = [
            { id: 1, title: 'Profil', icon: User, desc: 'Diri & Keluarga' },
            { id: 2, title: 'Harta Semasa', icon: Landmark, desc: 'Aset & Liabiliti' },
            { id: 3, title: 'Unjuran Bersara', icon: TrendingUp, desc: 'Pendidikan & Pencen' },
            { id: 4, title: 'Penyucian', icon: HeartHandshake, desc: 'Zakat Kehidupan' },
            { id: 5, title: 'Senario Mati', icon: Calculator, desc: 'Pusaka & Faraid' },
            { id: 6, title: 'Pelindung', icon: ShieldCheck, desc: 'Analisis Hibah/Waris' },
          ];

          const formatRM = (val) => new Intl.NumberFormat('ms-MY', { style: 'currency', currency: 'MYR', maximumFractionDigits: 0 }).format(val);

          // Fungsi untuk tukar tab & scroll ke atas
          const handleNextTab = () => {
            if (activeTab < 6) {
              setActiveTab(activeTab + 1);
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
          };

          const handlePrevTab = () => {
            if (activeTab > 1) {
              setActiveTab(activeTab - 1);
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
          };

          if (showReport) {
            return (
              <div className="min-h-screen bg-white text-slate-800 p-8 md:p-12 font-sans max-w-4xl mx-auto">
                <div className="print:hidden flex flex-col md:flex-row justify-between items-center gap-4 mb-8 bg-slate-100 p-4 rounded-xl">
                  <button onClick={() => setShowReport(false)} className="px-6 py-2 bg-slate-300 hover:bg-slate-400 text-slate-800 rounded-lg font-bold transition-colors w-full md:w-auto">
                    Kembali Ke Aplikasi
                  </button>
                  <div className="flex flex-col md:flex-row gap-3 w-full md:w-auto">
                    <button onClick={() => window.print()} className="px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-bold flex justify-center items-center gap-2 transition-colors">
                      <Printer size={18} /> Simpan / Cetak PDF
                    </button>
                    <a href="https://wa.me/60129443846?text=Salam,%20saya%20ingin%20berbincang%20berkenaan%20laporan%20myTADBIR%20saya." target="_blank" rel="noopener noreferrer" className="px-6 py-2 bg-green-500 hover:bg-green-600 text-white rounded-lg font-bold flex justify-center items-center gap-2 transition-colors">
                      <MessageCircle size={18} /> WhatsApp Perunding
                    </a>
                  </div>
                </div>

                <div className="border-b-2 border-emerald-800 pb-6 mb-8 text-center">
                  <h1 className="text-3xl font-black text-emerald-800 flex items-center justify-center gap-3 mb-2">
                    <Landmark size={32} className="text-amber-500" /> myTADBIR
                  </h1>
                  <p className="text-lg text-slate-600 font-semibold">Laporan Ringkasan Perancangan Kewangan & Harta Islam</p>
                </div>

                <div className="space-y-8">
                  <section>
                    <h2 className="text-xl font-bold text-slate-800 border-b pb-2 mb-4">1. Profil & Kedudukan Kewangan</h2>
                    <div className="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                      <div><span className="text-slate-500 block text-xs">Umur / Jantina:</span> <span className="font-semibold text-base">{age} Tahun ({userGender})</span></div>
                      <div><span className="text-slate-500 block text-xs">Tanggungan Anak:</span> <span className="font-semibold text-base">{childrenData.length} Orang</span></div>
                      <div><span className="text-slate-500 block text-xs">Pendapatan Tahunan:</span> <span className="font-semibold text-base">{formatRM(annualIncome)}</span></div>
                      <div><span className="text-slate-500 block text-xs">Perbelanjaan Bulanan:</span> <span className="font-semibold text-base">{formatRM(currentExpenses)}</span></div>
                    </div>
                  </section>

                  <section>
                    <h2 className="text-xl font-bold text-slate-800 border-b pb-2 mb-4">2. Ringkasan Harta & Hutang (Net Worth)</h2>
                    <div className="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
                      <div className="bg-slate-50 p-4 rounded-lg border border-slate-200 text-center md:text-left">
                        <p className="text-slate-500 mb-1">Jumlah Keseluruhan Aset</p>
                        <p className="font-bold text-xl text-emerald-600">{formatRM(totalLiquidAssets + totalPhysicalAssets)}</p>
                      </div>
                      <div className="bg-slate-50 p-4 rounded-lg border border-slate-200 text-center md:text-left">
                        <p className="text-slate-500 mb-1">Jumlah Hutang & Liabiliti</p>
                        <p className="font-bold text-xl text-red-600">{formatRM(totalDebts)}</p>
                      </div>
                      <div className="bg-emerald-50 p-4 rounded-lg border border-emerald-200 text-center md:text-left">
                        <p className="text-emerald-800 font-semibold mb-1">Nilai Harta Bersih</p>
                        <p className="font-black text-2xl text-emerald-700">{formatRM(currentNetWorth)}</p>
                      </div>
                    </div>
                  </section>

                  <section>
                    <h2 className="text-xl font-bold text-slate-800 border-b pb-2 mb-4">3. Unjuran Persaraan & Penyucian Harta</h2>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
                      <div className="bg-white border border-slate-200 rounded-lg p-4">
                        <h3 className="font-bold text-slate-700 mb-3 border-b pb-2">Status Dana Persaraan</h3>
                        <ul className="space-y-3">
                          <li className="flex justify-between"><span className="text-slate-500">Umur Sasaran Bersara:</span> <span className="font-semibold">{retireAge} Tahun</span></li>
                          <li className="flex justify-between"><span className="text-slate-500">Ketahanan Dana:</span> <span className="font-semibold">{yearsItWillLast.toFixed(1)} Tahun</span></li>
                          <li className="flex justify-between"><span className="text-slate-500">Defisit Dana (Kekurangan):</span> <span className={`font-bold ${retirementShortfall > 0 ? 'text-red-600' : 'text-emerald-600'}`}>{retirementShortfall > 0 ? formatRM(retirementShortfall) : 'Tiada'}</span></li>
                        </ul>
                      </div>
                      <div className="bg-white border border-slate-200 rounded-lg p-4">
                        <h3 className="font-bold text-slate-700 mb-3 border-b pb-2">Tanggungjawab Zakat Semasa</h3>
                        <ul className="space-y-3">
                          <li className="flex justify-between"><span className="text-slate-500">Harta Tunai Layak Zakat:</span> <span className="font-semibold">{formatRM(totalZakatable)}</span></li>
                          <li className="flex justify-between"><span className="text-slate-500">Zakat Wajib Ditunaikan (2.5%):</span> <span className="font-bold text-emerald-600">{formatRM(zakatPayable)}</span></li>
                        </ul>
                      </div>
                    </div>
                  </section>

                  <section>
                    <h2 className="text-xl font-bold text-slate-800 border-b pb-2 mb-4">4. Analisis Pusaka, Faraid & Pelindungan Waris</h2>
                    
                    <div className="bg-amber-50 p-5 rounded-lg border border-amber-200 text-sm mb-5">
                      <div className="flex flex-col md:flex-row justify-between items-start md:items-center mb-2 gap-2">
                        <span className="text-amber-900 font-bold text-base">Jurang Penggantian Pendapatan Waris (10 Tahun):</span>
                        <span className={`font-black text-xl ${incomeProtectionGap > 0 ? 'text-red-600' : 'text-emerald-600'}`}>
                          {incomeProtectionGap > 0 ? formatRM(incomeProtectionGap) + " (Defisit)" : "Mencukupi"}
                        </span>
                      </div>
                      <p className="text-slate-600 text-xs mt-1">*(Dikira berdasarkan keperluan belanja keluarga untuk 10 tahun, ditolak dengan Tuntutan Harta Sepencarian, Faraid Pasangan & Pampasan Takaful Sedia Ada)*</p>
                    </div>
                    
                    <div className="text-sm">
                      <p className="font-bold text-slate-800 mb-3">Tindakan Mitigasi & Pengurusan Harta Islam Yang Disyorkan:</p>
                      <ul className="list-disc pl-5 space-y-2 text-slate-700">
                        {incomeProtectionGap > 0 && <li>Sediakan dana pantas melalui pampasan <strong className="text-slate-900">Hibah Takaful</strong> bernilai minimum <strong>RM{formatRM(incomeProtectionGap)}</strong> untuk waris anda segera.</li>}
                        {totalLiquidAssets > 0 && <li>Wujudkan <strong className="text-slate-900">Amanah Tunai (Cash Trust)</strong> bagi mengelakkan akaun bank dibekukan, dan memudahkan waris mengeluarkan tunai pantas.</li>}
                        {hasSpouse && <li>Daftarkan <strong className="text-slate-900">Deklarasi Harta Sepencarian</strong> secara rasmi untuk menjamin pemilikan ({sepencarianPercent}%) aset fizikal oleh isteri/suami anda.</li>}
                        <li>Sediakan <strong>Wasiat Pentadbir</strong> untuk memastikan proses penyelesaian hutang tertunggak (RM{formatRM(totalDebts)}) berjalan lancar.</li>
                      </ul>
                    </div>
                  </section>
                </div>

                <div className="mt-12 pt-8 border-t border-slate-200 text-center">
                  <p className="text-sm font-semibold text-slate-800 mb-2">Hubungi Perunding Kewangan Anda</p>
                  <p className="text-xs text-slate-500 mb-6 print:mb-2 max-w-2xl mx-auto">Laporan ini dijana oleh myTADBIR dan merupakan anggaran asas kedudukan perancangan harta anda. Sila berhubung dengan perunding yang sah untuk rundingan yang lebih komprehensif.</p>
                  
                  <a href="https://wa.me/60129443846?text=Salam,%20saya%20ingin%20berbincang%20berkenaan%20laporan%20myTADBIR%20saya." target="_blank" rel="noopener noreferrer" className="inline-flex items-center justify-center gap-2 px-8 py-4 bg-green-500 hover:bg-green-600 transition-colors text-white font-bold rounded-full shadow-lg text-base decoration-transparent print:hidden">
                    <MessageCircle size={22} /> WhatsApp Sekarang: 012-9443846
                  </a>
                  
                  <div className="hidden print:block text-slate-800 font-bold text-lg mt-4 p-4 border-2 border-slate-800 rounded-lg inline-block">
                    No. Telefon Perunding: 012-9443846
                  </div>
                </div>
              </div>
            );
          }

          return (
            <div className="min-h-screen bg-slate-50 font-sans pb-12">
              <header className="bg-emerald-800 text-white p-6 md:p-10 shadow-md">
                <div className="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
                  <div>
                    <h1 className="text-3xl font-bold flex items-center gap-3">
                      <Landmark size={32} className="text-amber-400" />
                      myTADBIR
                    </h1>
                    <p className="text-emerald-100 mt-2 text-lg">Perancangan Persaraan Dunia Akhirat Anda</p>
                  </div>
                  <div className="bg-emerald-900/50 p-4 rounded-xl border border-emerald-700 backdrop-blur-sm text-right">
                    <p className="text-emerald-200 text-sm">Nilai Harta Bersih Semasa</p>
                    <p className="text-2xl font-bold text-amber-400">{formatRM(currentNetWorth)}</p>
                  </div>
                </div>
              </header>

              <main className="max-w-6xl mx-auto mt-8 px-4">
                <div className="flex overflow-x-auto gap-3 mb-8 pb-4 snap-x hide-scrollbar">
                  {tabs.map((tab) => (
                    <button
                      key={tab.id}
                      onClick={() => setActiveTab(tab.id)}
                      className={`flex-none w-[160px] md:flex-1 md:w-auto flex flex-col items-center justify-center gap-2 p-4 rounded-xl font-medium transition-all snap-center ${
                        activeTab === tab.id 
                          ? 'bg-emerald-600 text-white shadow-lg scale-105 transform border-emerald-500' 
                          : 'bg-white text-slate-600 hover:bg-emerald-50 border border-slate-200'
                      }`}
                    >
