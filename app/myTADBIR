                          <div className="flex items-center gap-3">
                            <PieChart className="text-emerald-600" size={28} />
                            <h2 className="text-xl font-bold text-slate-800">Pembahagian Faraid Waris</h2>
                          </div>
                          <div className="flex gap-4 text-sm bg-slate-100 p-2 rounded-lg">
                            <label className="flex items-center gap-2 cursor-pointer">
                              <input type="checkbox" checked={hasSpouse} onChange={(e) => setHasSpouse(e.target.checked)} className="accent-emerald-600" />
                              Pasangan Hidup
                            </label>
                            <select value={parentsAlive} onChange={(e) => setParentsAlive(Number(e.target.value))} className="bg-transparent border-none outline-none font-semibold text-emerald-800">
                              <option value={0}>Ibu Bapa Tiada</option><option value={1}>Ibu/Bapa Hidup</option><option value={2}>Keduanya Hidup</option>
                            </select>
                          </div>
                        </div>
                        
                        {actualNetEstate <= 0 ? (
                          <div className="text-center p-8 bg-red-50 rounded-xl border border-red-200">
                            <AlertTriangle size={40} className="mx-auto text-red-500 mb-3" />
                            <h3 className="font-bold text-red-800 text-lg">Harta Pusaka Defisit!</h3>
                            <p className="text-red-600 mt-2">Hutang anda melepasi nilai aset. Tiada sebarang harta yang tinggal untuk diagihkan secara Faraid. Waris anda kini terbeban.</p>
                          </div>
                        ) : (
                          <div className="overflow-x-auto">
                            <table className="w-full text-left border-collapse">
                              <thead>
                                <tr className="bg-emerald-50 border-b border-emerald-200">
                                  <th className="p-4 font-semibold text-emerald-800">Waris (Dari Profil)</th>
                                  <th className="p-4 font-semibold text-emerald-800 text-right">Kadar Bahagian</th>
                                  <th className="p-4 font-semibold text-emerald-800 text-right">Nilai Diterima (RM)</th>
                                </tr>
                              </thead>
                              <tbody>
                                {faraidDistribution.map((item, index) => (
                                  <tr key={index} className="border-b border-slate-100 hover:bg-slate-50 transition-colors">
                                    <td className="p-4 text-slate-800 font-medium">{item.name}</td>
                                    <td className="p-4 text-slate-600 text-right">{item.percent.toFixed(2)}%</td>
                                    <td className="p-4 text-emerald-600 font-bold text-right">{formatRM(item.amount)}</td>
                                  </tr>
                                ))}
                              </tbody>
                            </table>
                          </div>
                        )}
                      </Card>
                    </div>
                  )}

                  {/* TAHAP 6: PELINDUNG & HIBAH (AHA MOMENT) */}
                  {activeTab === 6 && (
                    <div className="space-y-6 animate-fadeIn">
                      <Card className="bg-gradient-to-br from-slate-800 to-slate-900 text-white border-none">
                        <div className="flex flex-col md:flex-row justify-between items-center gap-6">
                          <div className="flex-1">
                            <h2 className="text-2xl font-bold flex items-center gap-3 mb-2 text-amber-400">
                              <Heart size={28} /> Realiti Untuk Pasangan (Waris) Anda
                            </h2>
                            <p className="text-slate-300 text-sm leading-relaxed">
                              Jika anda meninggal dunia hari ini, Faraid akan membahagikan harta tunai anda kepada waris lain (termasuk ibu bapa atau adik beradik). Adakah bahagian yang diterima isteri/suami cukup untuk meneruskan kehidupan dan membesarkan anak-anak?
                            </p>
                          </div>
                          <div className="w-full md:w-1/3 bg-white p-4 rounded-xl shadow-inner text-black">
                            <Input label="Hibah / Takaful Semasa Anda" value={currentTakaful} onChange={e => setCurrentTakaful(Number(e.target.value))} prefix="RM" />
                          </div>
                        </div>
                      </Card>

                      <div className="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
                        <Card className="flex flex-col border-blue-200 shadow-sm">
                          <h3 className="font-bold text-slate-800 mb-4 text-lg border-b pb-2">Jumlah Dana Diterima Pasangan</h3>
                          <div className="space-y-4 flex-1 flex flex-col justify-center">
                            <div className="flex justify-between items-center">
                              <span className="text-slate-600">Harta Sepencarian (Tuntutan Fizikal):</span>
                              <span className="font-semibold text-blue-600">{formatRM(sepencarianAmount)}</span>
                            </div>
                            <div className="flex justify-between items-center">
                              <span className="text-slate-600">Bahagian Faraid Pasangan ({spouseFaraidObj ? spouseFaraidObj.percent.toFixed(2) : 0}%):</span>
                              <span className="font-semibold text-emerald-600">{formatRM(spouseFaraidAmount)}</span>
                            </div>
                            <div className="flex justify-between items-center">
                              <span className="text-slate-600">Pampasan Hibah Takaful Sedia Ada:</span>
                              <span className="font-semibold text-amber-500">{formatRM(currentTakaful)}</span>
                            </div>
                            <div className="pt-4 mt-2 border-t border-slate-200">
                              <p className="text-sm text-slate-500 mb-1">TOTAL DANA SURVIVAL PASANGAN:</p>
                              <p className="text-3xl font-extrabold text-slate-800">{formatRM(totalSpouseSurvivalFund)}</p>
                            </div>
                          </div>
                        </Card>

                        <Card className="flex flex-col bg-amber-50 border-amber-200 shadow-sm">
                          <h3 className="font-bold text-amber-900 mb-4 text-lg border-b border-amber-200 pb-2">Analisis Jurang Pendapatan (Income Replacement)</h3>
                          <div className="space-y-4 flex-1 flex flex-col justify-center">
                            <div className="bg-white p-4 rounded-lg border border-amber-100">
                              <p className="text-sm text-amber-700 mb-1">Standard: 10 Tahun Perbelanjaan Keluarga</p>
                              <p className="text-2xl font-bold text-amber-600">{formatRM(familySurvivalNeeds)}</p>
                              <p className="text-xs text-slate-400 mt-1">({formatRM(currentExpenses)} / bulan x 12 bulan x 10 Tahun)</p>
                            </div>

                            <div className="flex justify-between items-center pt-2">
                              <span className="text-slate-700 font-semibold text-lg">Jurang Dana Kekurangan:</span>
                              <span className={`font-bold text-2xl ${incomeProtectionGap > 0 ? 'text-red-600' : 'text-emerald-600'}`}>
                                {incomeProtectionGap > 0 ? formatRM(incomeProtectionGap) : 'Mencukupi'}
                              </span>
                            </div>

                            {incomeProtectionGap > 0 ? (
                              <div className="mt-2 text-sm text-red-700 bg-red-100 p-4 rounded-lg border border-red-200 leading-relaxed">
                                <strong>Kesimpulan:</strong> Pasangan anda akan kekurangan dana sebanyak <strong>{formatRM(incomeProtectionGap)}</strong> untuk membesarkan anak-anak selama 10 tahun. Disinilah fungsi <strong>Hibah Takaful</strong>—ia adalah pampasan tunai mutlak tanpa perlu melalui proses panjang Faraid untuk menampung jurang ini.
                              </div>
                            ) : (
                              <div className="mt-2 text-sm text-emerald-800 bg-emerald-100 p-4 rounded-lg border border-emerald-200 leading-relaxed">
                                <strong>Tahniah:</strong> Gabungan Faraid dan Takaful sedia ada sudah memadai untuk menampung keluarga selama 10 tahun.
                              </div>
                            )}
                          </div>
                        </Card>
                      </div>

                      {/* AHA MOMENT: CHECKLIST SOLUSI PELINDUNGAN */}
                      <div className="mt-8 mb-4">
                        <div className="flex items-center gap-2 mb-4">
                          <FileText size={24} className="text-slate-800" />
                          <h3 className="text-xl font-bold text-slate-800">Checklist Solusi Pelindungan & Legasi Islam</h3>
                        </div>
                        <p className="text-slate-600 mb-6 text-sm">Berdasarkan profil kewangan dan nilai bersih harta anda, berikut adalah instrumen pengurusan harta Islam yang wajib dipertimbangkan dengan segera:</p>
                        
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                          {/* Instrumen 1: Hibah Takaful */}
                          <div className={`flex items-start gap-4 p-5 bg-white rounded-xl border ${incomeProtectionGap > 0 ? 'border-red-300 ring-2 ring-red-100' : 'border-slate-200'} shadow-sm transition-all hover:shadow-md`}>
                            <div className={`p-3 rounded-full shrink-0 ${incomeProtectionGap > 0 ? 'bg-red-100 text-red-600' : 'bg-emerald-100 text-emerald-600'}`}>
                              <ShieldCheck size={24} />
                            </div>
                            <div>
                              <div className="flex justify-between items-start">
                                <h4 className="font-bold text-slate-800">Hibah Takaful (Income Replacement)</h4>
                                {incomeProtectionGap > 0 && <span className="text-[10px] bg-red-500 text-white px-2 py-0.5 rounded uppercase font-bold tracking-wide">Kritikal</span>}
                              </div>
                              <p className="text-sm text-slate-600 mt-1">
                                Sediakan polisi bernilai <strong className="text-slate-800">{incomeProtectionGap > 0 ? `RM${formatRM(incomeProtectionGap)}` : 'tambahan'}</strong>. Pampasan tunai ini tidak akan dibekukan oleh sistem pusaka dan terus dibayar kepada penama untuk teruskan hidup.
                              </p>
                            </div>
                          </div>

                          {/* Instrumen 2: Amanah Tunai */}
                          <div className="flex items-start gap-4 p-5 bg-white rounded-xl border border-slate-200 shadow-sm transition-all hover:shadow-md">
                            <div className="p-3 rounded-full shrink-0 bg-blue-100 text-blue-600">
                              <Wallet size={24} />
                            </div>
                            <div>
                              <h4 className="font-bold text-slate-800">Amanah Tunai (Cash Trust)</h4>
                              <p className="text-sm text-slate-600 mt-1">
                                Anda memiliki <strong className="text-slate-800">RM{formatRM(totalLiquidAssets)}</strong> aset cair. Gunakan sebahagiannya untuk didaftarkan sebagai 'Deklarasi Hibah Tunai'. Duit ini boleh dikeluarkan dalam masa 7-14 hari jika kematian berlaku.
                              </p>
                            </div>
                          </div>

                          {/* Instrumen 3: Harta Sepencarian */}
                          {hasSpouse && (
                            <div className="flex items-start gap-4 p-5 bg-white rounded-xl border border-slate-200 shadow-sm transition-all hover:shadow-md">
                              <div className="p-3 rounded-full shrink-0 bg-amber-100 text-amber-600">
                                <Heart size={24} />
                              </div>
                              <div>
                                <h4 className="font-bold text-slate-800">Deklarasi Harta Sepencarian Berdaftar</h4>
                                <p className="text-sm text-slate-600 mt-1">
                                  Daftarkan dokumen persetujuan ini di mahkamah semasa hidup. Anda boleh wariskan 50%-100% hak milik aset seperti rumah (<strong className="text-slate-800">RM{formatRM(rumahValue)}</strong>) mutlak kepada pasangan agar tidak menjadi rebutan waris.
                                </p>
                              </div>
                            </div>
                          )}

                          {/* Instrumen 4: Amanah Hayat (Living Trust) / Wakaf */}
                          <div className="flex items-start gap-4 p-5 bg-white rounded-xl border border-slate-200 shadow-sm transition-all hover:shadow-md">
                            <div className="p-3 rounded-full shrink-0 bg-purple-100 text-purple-600">
                              <BookOpen size={24} />
                            </div>
                            <div>
                              <h4 className="font-bold text-slate-800">Amanah Hayat & Wakaf Keluarga</h4>
                              <p className="text-sm text-slate-600 mt-1">
                                Lantik pemegang amanah korporat untuk menguruskan harta bagi pihak anak bawah umur (18 tahun) atau wujudkan dana wakaf amal jariah menggunakan wang lebihan untuk bekalan akhirat.
                              </p>
                            </div>
                          </div>
                        </div>
                      </div>

                    </div>
                  )}
                </div>

                {/* --- BUTANG NAVIGASI HALAMAN BAWAH --- */}
                <div className="mt-8 flex justify-between items-center border-t border-slate-200 pt-6">
                  {activeTab > 1 ? (
                    <button
                      onClick={handlePrevTab}
                      className="px-6 py-3 bg-white text-slate-600 hover:bg-slate-100 hover:text-slate-800 border border-slate-300 font-bold rounded-xl transition-colors shadow-sm"
                    >
                      Kembali
                    </button>
                  ) : (
                    <div></div> /* Empty div untuk spacing bila butang kembali tiada */
                  )}

                  {activeTab < 6 ? (
                    <button
                      onClick={handleNextTab}
                      className="px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl flex items-center gap-2 transition-colors shadow-sm ml-auto"
                    >
                      Seterusnya <ArrowRight size={20} />
                    </button>
                  ) : (
                    <div className="flex flex-col md:flex-row gap-3 ml-auto w-full md:w-auto mt-4 md:mt-0">
                      <button
                        onClick={() => {
                          setShowReport(true);
                          window.scrollTo({ top: 0, behavior: 'smooth' });
                        }}
                        className="px-6 py-3 bg-amber-500 hover:bg-amber-600 text-white font-bold rounded-xl flex items-center justify-center gap-2 transition-colors shadow-sm w-full md:w-auto"
                      >
                        <Printer size={20} /> Jana Laporan PDF
                      </button>
                      <button
                        onClick={() => {
                          setActiveTab(1);
                          window.scrollTo({ top: 0, behavior: 'smooth' });
                        }}
                        className="px-6 py-3 bg-slate-800 hover:bg-slate-900 text-white font-bold rounded-xl transition-colors shadow-sm w-full md:w-auto text-center"
                      >
                        Mula Semula
                      </button>
                    </div>
                  )}
                </div>

              </main>
              
              <footer className="max-w-6xl mx-auto mt-12 text-center text-slate-500 text-sm">
                <p>myTADBIR: Membantu anda merancang legasi kewangan dan kelangsungan hidup waris mengikut prinsip Islam.</p>
              </footer>
            </div>
          );
        }

        const root = createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
